# Supabase Configuration for ARLibro
# Copia este archivo a .env y llena con tus credenciales

# Tu Supabase Project URL
# Obtén de: https://app.supabase.com/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co

# Tu Supabase Anon Key (Public) - Se usa si no tienes Service Role Key
# Obtén de: https://app.supabase.com/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# RECOMENDADO: Tu Supabase Service Role Key (Privada) - Usada solo en el Backend
# Obtén de: https://app.supabase.com/project/YOUR_PROJECT/settings/api
# ⚠️ NUNCA compartas esta clave - Solo debe estar en el servidor
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
